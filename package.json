{
  "name": "bullebrowser-monorepo",
  "version": "0.1.2",
  "private": true,
  "description": "BulleBrowser monorepo \u2014 agentic browser by Bulle Consulting",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @bullebrowser/desktop dev",
    "dev:web": "pnpm --filter @bullebrowser/web dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @bullebrowser/desktop build",
    "build:web": "pnpm --filter @bullebrowser/web build",
    "package:desktop": "pnpm --filter @bullebrowser/desktop package",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "author": {
    "name": "Bulle Consulting",
    "email": "hello@bulleconsulting.com"
  },
  "homepage": "https://bullebrowser.com"
}
